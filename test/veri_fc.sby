[tasks]
taskcover prove_cover
taskbmc prove_bmc

[options]
prove_cover: mode cover
prove_cover: depth 100
prove_bmc: mode bmc

[engines]
smtbmc

[files]
../src/freq_counter.v
../src/rising_edge_detect.v

[script]
read -formal rising_edge_detect.v
read -formal freq_counter.v
prep -top freq_counter -chparam WATCHDOG_TICK 10